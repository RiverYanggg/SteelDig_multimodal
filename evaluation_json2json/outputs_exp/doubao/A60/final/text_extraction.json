{
  "papers": [
    {
      "paper_id": "A60",
      "doi": "10.1016/j.corsci.2025.113331",
      "title": "Enhancing the corrosion resistance of low-density steels via Al-rich oxide film formation by grain size optimization",
      "authors": [
        "Guang Yang",
        "Li Wang",
        "Xiaoqian Fu",
        "Yucheng Ji",
        "Wenquan Cao",
        "Cunyu Wang",
        "Jianxiong Liang",
        "Chaofang Dong"
      ],
      "publication_year": "2025",
      "journal": "Corrosion Science",
      "keywords": [
        "Low-density steels",
        "Grain size",
        "Microstructure",
        "Oxide film",
        "Corrosion resistance"
      ],
      "research_type": "experimental",
      "paper_scope": "This study investigates the effects of grain size on oxide film formation and corrosion behavior of Fe-Mn-Al-C low-density steels (LDSs). LDSs with grain sizes ranging from 8.7 μm to 32 μm are prepared by adjusting solution treatment temperature between 950 ℃ and 1150 ℃, revealing that grain refinement promotes the formation of uniform and stable Al-rich oxide film, thus improving corrosion resistance."
    }
  ],
