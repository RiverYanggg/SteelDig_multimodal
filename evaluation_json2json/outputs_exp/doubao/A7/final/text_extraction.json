{
  "papers": [
    {
      "paper_id": "A7",
      "doi": null,
      "title": "Factors influencing austenite stability during Inter-critical annealing and effect on mechanical properties of low-density medium Mn steels",
      "authors": [
        "Kishan Bharti",
        "Nitin Kumar Sharma"
      ],
      "publication_year": null,
      "journal": null,
      "keywords": [
        "Advanced high strength steels (AHSS)",
        "Low density steel (LDS)",
        "Intercritical annealing (IA)",
        "Retained austenite (RA)",
        "Transformation induced plasticity (TRIP)"
      ],
      "research_type": "experimental",
      "paper_scope": "研究向Fe-8Mn-0.2C中锰钢体系添加3wt%Al（含或不含1wt%Si）后，临界退火过程中奥氏体稳定性的影响因素及其对力学性能的调控作用，揭示了元素偏析、晶粒尺寸等局部微观结构不均匀性对奥氏体稳定性的作用机制，获得了强塑积优异的低密度中锰钢材料"
    }
  ],
