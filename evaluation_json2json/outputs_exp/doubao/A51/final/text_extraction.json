    {
      "paper_id": "A51",
      "doi": "10.1002/adem.202301595",
      "title": "Tailoring Strength and Ductility of an Fe–Mn–Al–C Low-Density Duplex Steel by Controlling the Cooling Path after Hot Rolling",
      "authors": [
        "Zhenlei Li",
        "Rong Chen",
        "Yi Wang",
        "Long Gao",
        "Xiaowu Li"
      ],
      "publication_year": "2023",
      "journal": "Advanced Engineering Materials",
      "keywords": [
        "low-density duplex steel",
        "Fe-Mn-Al-C steel",
        "cooling path after hot rolling",
        "microstructure evolution",
        "tensile properties",
        "TRIP effect",
        "strength-ductility synergy"
      ],
      "research_type": "experimental",
      "paper_scope": "This work investigates the effect of air cooling vs furnace cooling after hot rolling, combined with subsequent annealing at 800-1000 °C, on the microstructure evolution and tensile properties of an Fe-8.03Mn-6.10Al-0.4C low-density duplex steel, to provide a scalable production route for optimizing strength-ductility match of such steels."
    }
