{
  "papers": [
    {
      "paper_id": "A48",
      "doi": null,
      "title": "Chemical Composition Optimization for Austenitic Steels of the Fe-Mn-Al-C System",
      "authors": [
        "I. Kalashnikov",
        "O. Acselrad",
        "A. Shalkevich",
        "L.C. Pereira"
      ],
      "publication_year": "2000",
      "journal": null,
      "keywords": [
        "austenitic steels",
        "FeMnAlC alloys",
        "mechanical properties"
      ],
      "research_type": "experimental",
      "paper_scope": "Aiming at the lack of systematic composition design criteria for Fe-Mn-Al-C austenitic steels, this paper studies the effects of Mn, Al and C contents on microstructure and mechanical properties, and optimizes the composition range to obtain an optimal microstructure without embrittling phases, meeting the combination of tensile strength (UTS > 1100 MPa) and impact toughness (KCU > 50 J/cm²) required for structural applications."
    }
  ],
  "alloys": [
    {
      "alloy_id": "alloy_femnalc",
      "paper_id": "A48",
      "alloy_name": "Fe-Mn-Al-C system austenitic steel",
      "aliases": [],
      "base_element": "Fe",
      "alloying_elements": [
        "Mn",
        "Al",
        "C"
      ],
      "nominal_composition": [
        {
          "element": "Mn",
          "weight_percent": "24%~34%",
          "atomic_percent": null
        },
        {
          "element": "Al",
          "weight_percent": "3%~14%",
          "atomic_percent": null
        },
        {
          "element": "C",
          "weight_percent": "0.3%~1.2%",
          "atomic_percent": null
        },
        {
          "element": "Fe",
          "weight_percent": "bal",
          "atomic_percent": null
        }
      ],
      "alloys_notes": "The optimized industrial composition range is Al: 9%~9.5 wt%, C: 0.9%~0.95 wt%, Mn: 28.5%~30.5 wt%; the composition range for microstructure free of embrittling phases is Al: 6.2%~9.7 wt%, C: 0.7%~1 wt%, Mn: 25%~31 wt%."
    }
  ],
  "processes": [
    {
      "process_id": "proc_femnalc_01",
      "paper_id": "A48",
      "alloy_id": "alloy_femnalc",
      "description": "100 kg induction furnace melting, electroslag remelting refining, 1150 °C homogenization for 6~8 h, hot working into rods, 1050 °C water quenching, 550 °C aging for 16 h",
      "processes_notes": "Hot working at 1150~1170 °C can dissolve δ-ferrite with volume fraction ≤12% in as-cast structure."
    },
    {
      "process_id": "proc_femnalc_02",
      "paper_id": "A48",
      "alloy_id": "alloy_femnalc",
      "description": "Jet spraying atomization in argon atmosphere for rapid solidification, pressing at 1150 °C, quenching from 1100 °C",
      "processes_notes": "Rapid solidification can suppress segregation, avoiding δ-ferrite formation when Al content is up to 12 wt%."
    }
  ],
