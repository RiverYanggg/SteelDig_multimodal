        {
          "model_name": "Elastic modulus prediction model for steels",
          "equation_role": "E_Steel = Σ r_i * C_i, where C_i is mass content of component i in wt%, r_i is regression coefficient for component i",
          "parameters": null,
          "model_note": "Valid within the concentration ranges given in Tables 1-3"
        }
      ]
    }
