      "journal": null,
      "keywords": [
        "Low density steel",
        "Alloying effects",
        "Mechanical property",
        "Impact toughness",
        "κ-carbides"
      ],
      "research_type": "experimental",
      "paper_scope": "系统研究C（0.6~1.5wt%）、Mn（20~35wt%）、Al（6~12wt%）含量对Fe-Mn-Al-C低密度钢固溶处理后微观组织（相组成、晶粒尺寸、κ碳化物尺寸等）、密度、拉伸性能及-40℃冲击韧性的影响规律，建立密度与合金含量的定量关系，揭示κ碳化物对力学性能的作用机制，为高性能低密度钢成分设计提供指导"
    }
