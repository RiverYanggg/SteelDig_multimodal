    {
      "paper_id": "A18",
      "doi": null,
      "title": "Effect of alloying content on microstructure and mechanical properties of Fe–Mn–Al–C low-density steels",
      "authors": [
        "Hui Wang",
        "Cunyu Wang",
        "Jianxiong Liang",
