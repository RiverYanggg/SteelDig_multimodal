      "analytical_model": [
        {
          "model_name": "stacking fault energy calculation model",
          "equation_role": "计算奥氏体的堆垛层错能",
          "parameters": "γ_SFE = 2ρΔG^γ→ε + 2σ，其中ρ为{111}面摩尔面密度，ΔG^γ→ε为γ→ε相变摩尔吉布斯自由能，σ为γ/ε相界面能",
          "model_note": "计算得到4Al、6Al、8Al钢奥氏体堆垛层错能分别为51.25、62.64、68.47 mJ·m⁻²"
        },
        {
          "model_name": "flow stress calculation model",
          "equation_role": "计算8Al钢的流变应力",
          "parameters": "σ_tot = σ0 + 0.757σ_α(ε) + 0.243σ_γ(ε)，其中σ_α(ε)为铁素体滑移带细化的强化贡献，σ_γ(ε)为奥氏体位错结构细化的强化贡献",
          "model_note": "计算结果与实验值吻合良好，证实动态滑移带细化是8Al钢主要强化机制"
        }
      ]
    }
