    {
      "paper_id": "A8",
      "doi": null,
      "title": "Effect of annealing temperature on the microstructure and tensile properties of Fe–10Mn–10Al–0.7C low-density steel",
      "authors": [
        "Chao Zhao",
        "Renbo Song",
        "Leifeng Zhang",
        "Fuqiang Yang",
        "Tai Kang"
      ],
      "publication_year": "2015",
      "journal": null,
      "keywords": [
        "Low-density steel",
        "Annealing",
        "κ-Carbide",
        "Tensile properties"
      ],
      "research_type": "experimental",
      "paper_scope": "研究了Fe-10Mn-10Al-0.7C低密度钢在700℃~1200℃温度范围内退火1h后的组织演化与拉伸性能，明确了退火温度对相组成、晶粒尺寸的影响规律，揭示了组织与拉伸性能的关联机制，为低Mn含量Fe-Mn-Al-C低密度钢的设计与热处理工艺优化提供参考"
    }
  ],
