  "computational_details": [
    {
      "computation_id": "comp_sfe_01",
      "sample_id": null,
      "simulation_method": null,
      "software_used": null,
      "potential_model": null,
      "validation_against_experiment": "yes",
      "analytical_model": [
        {
          "model_name": "层错能计算公式",
          "equation_role": "通过偏位错间距、晶格参数计算层错能",
          "parameters": "剪切模量G=74 GPa，泊松比v=0.3",
          "model_note": "SFE = (G|a₀|²(2-v)/(48π(1-v)))·(1/d)·(1 - 2v cos2α/(2-v))，其中d为偏位错间距，α为完美位错特征角"
        }
      ]
    }
  ],
  "unmapped_findings": [
    "忽略Al对奥氏体晶格参数的影响会导致Al合金化先进高强度钢(AHSS)中碳含量高估，当Al含量为1 wt.%时，高估范围为0.125-0.176 wt.%",
    "Si的线性晶格参数系数A^LP为-0.018×10^-3 nm·wt.%^-1，Al的线性晶格参数系数A^LP为0.582×10^-3 nm·wt.%^-1，与文献报道值一致",
    "Si的线性层错能系数A^SFE为-2.6 mJ·m^-2·wt.%^-1，Al的线性层错能系数A^SFE为4.9 mJ·m^-2·wt.%^-1，与高Mn钢文献报道值吻合",
    "若考虑弹性各向异性，2.5 Al合金的SFE计算值会提高约10%，其余合金SFE变化小于1 mJ·m^-2"
  ]
}