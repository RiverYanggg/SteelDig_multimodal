      "validation_against_experiment": "计算结果与实验屈服强度吻合度较高",
      "analytical_model": [
        {
          "model_name": "固溶强化模型",
          "equation_role": "计算Al元素的固溶强化贡献",
          "parameters": "k_c=17.54 MPa/wt%Al，σ_s0=275.57 MPa，m=1",
          "model_note": "σ_s = σ_s0 + k_c * c^m，c为奥氏体中Al的质量分数"
        },
