{
  "papers": [
    {
      "paper_id": "A27",
      "doi": null,
      "title": "Deformation behaviour of iron-rich iron-aluminum alloys at low temperatures",
      "authors": [
        "J. Herrmann",
        "G. Inden",
        "G. Sauthoff"
      ],
      "publication_year": "2003",
      "journal": "Acta Materialia",
      "keywords": [
        "Iron alloys",
        "Short-range ordering",
        "Mechanical properties",
        "Yield phenomena",
        "Fe-Al alloys"
      ],
      "research_type": "experimental",
      "paper_scope": "研究Al含量最高18at.%、杂质含量低（尤其是C含量低于100wt.ppm）的二元单晶和多晶Fe-Al合金在室温和-100℃下的变形行为，明确强度和塑性对Al含量、短程有序的依赖关系，探讨淬火、退火处理对铸态材料性能的影响"
    }
  ],
