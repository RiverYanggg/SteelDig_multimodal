    {
      "paper_id": "A12",
      "doi": null,
      "title": "Tensile deformation behavior analysis of low density Fe–18Mn–10Al– xC steels",
      "authors": [
        "Hua Ding",
        "Dong Han",
        "Jun Zhang",
        "Zhihui Cai",
        "Zhiqiang Wu",
        "Minghui Cai"
      ],
      "publication_year": "2015",
      "journal": null,
      "keywords": [
        "Fe–Mn–Al–C steels",
        "Strain hardening",
        "Ordered phase",
        "C concentration",
        "Crussard–Jaoul (C–J) analysis"
      ],
      "research_type": "experimental",
      "paper_scope": "研究含0.5、0.8和1.2 wt% C的低密度Fe–18Mn–10Al–xC钢的微观结构差异及其对塑性变形过程中力学行为的影响，通过Crussard–Jaoul分析阐明不同相组成钢的力学行为差异，为低密度Fe–Mn–Al–C钢的合金设计和应用提供参考数据"
    }
