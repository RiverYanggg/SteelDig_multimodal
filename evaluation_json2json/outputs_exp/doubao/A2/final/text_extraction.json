    {
      "paper_id": "A2",
      "doi": null,
      "title": "Work hardening in Fe–Al alloys",
      "authors": [
        "D.G. Morris",
        "M.A. Munoz-Morris",
        "L.M. Requejo"
      ],
      "publication_year": "2007",
      "journal": null,
      "keywords": [
        "Iron alloys",
        "Intermetallic phases—iron aluminides",
        "Mechanical properties",
        "Work hardening"
      ],
      "research_type": "experimental",
      "paper_scope": "研究Al含量从近0到40at.%的多晶Fe-Al合金室温加工硬化行为，结合力学性能测试、透射电镜位错结构表征，解释26~30at.%Al区间加工硬化尖锐峰值的形成机理，讨论位错类型、偶极子形成、Peierls力、弹性各向异性及位错反应对加工硬化的调控作用"
    }
