  "processes": [
    {
      "process_id": "proc_lab_melt_casting",
      "paper_id": "A1",
      "alloy_id": null,
      "description": "实验室规模采用标准熔炼工艺制备~50kg小钢锭，钢锭在1100-1250℃下均质化1-3h以消除元素偏析",
      "processes_notes": null
    },
    {
      "process_id": "proc_hot_rolling",
      "paper_id": "A1",
      "alloy_id": null,
      "description": "均质化后将钢坯热轧至2-5mm厚度，终轧温度控制在850-1000℃，轧后可选择冷却至500-650℃保温1-5h模拟卷取，或直接水淬/空冷至室温",
      "processes_notes": "高Al钢热轧过程中易出现表面氧化层难以去除、热开裂等问题"
    },
    {
      "process_id": "proc_solution_quench",
      "paper_id": "A1",
      "alloy_id": "alloy_austenitic_fe_mn_al_c",
      "description": "将热轧/冷轧试样在900-1100℃下固溶处理，使析出相充分溶解，随后快速水淬/油淬至室温，抑制晶界κ*碳化物析出",
      "processes_notes": "冷却速率影响SRO和κ'-carbide的析出程度，慢冷会增加析出密度"
    },
    {
      "process_id": "proc_aging_treatment",
      "paper_id": "A1",
      "alloy_id": "alloy_austenitic_fe_mn_al_c",
      "description": "将固溶水淬后的试样在500-700℃下保温5-20h进行时效处理，析出纳米级κ'-carbide产生时效硬化",
      "processes_notes": "时效温度过高或时间过长会导致晶界粗化κ*碳化物析出，显著降低塑性和韧性"
    },
    {
      "process_id": "proc_cold_rolling_annealing_ferritic",
      "paper_id": "A1",
      "alloy_id": "alloy_ferritic_fe_al",
      "description": "热轧铁素体钢经冷轧后，在700-1000℃下进行再结晶退火，控制铁素体晶粒尺寸和织构，抑制Cube织构的形成",
      "processes_notes": "可添加微量Nb、Ti等微合金元素通过粒子激发形核机制细化晶粒"
    },
    {
      "process_id": "proc_intercritical_annealing_duplex",
      "paper_id": "A1",
      "alloy_id": "alloy_duplex_ferrite_based",
      "description": "冷轧双相钢在700-900℃临界区退火后，快速冷却至400℃左右进行等温淬火，调控残余奥氏体的稳定性以利用TRIP/TWIP效应",
      "processes_notes": null
    }
  ],
