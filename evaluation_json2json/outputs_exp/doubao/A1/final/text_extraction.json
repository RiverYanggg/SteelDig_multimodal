{
  "papers": [
    {
      "paper_id": "A1",
      "doi": null,
      "title": "Current state of Fe-Mn-Al-C low density steels",
      "authors": [
        "Shangping Chen",
        "Radhakanta Rana",
        "Arunansu Haldar",
        "Ranjit Kumar Ray"
      ],
      "publication_year": "2017",
      "journal": null,
      "keywords": [
        "Low density steels",
        "Deformation mechanisms",
        "Phase transformation",
        "Short-range ordering",
        "κ-carbide",
        "Planar glide",
        "TRIP steel",
        "TWIP steel",
        "Stacking fault energy"
      ],
      "research_type": "review",
      "paper_scope": "本文综述了多年公开文献中Fe-Mn-Al-C低密度钢的物理冶金、加工策略、强化机制和力学性能，梳理了该类钢的分类、相图热力学、微观组织演化规律，总结了其拉伸、冲击、高应变率等性能特征，并提出了该合金在汽车领域未来应用的发展方向和待解决的关键问题"
    }
  ],
