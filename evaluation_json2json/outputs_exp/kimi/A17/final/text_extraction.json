          "parameters": "M = 2.73, G = 75.34 GPa, ν = 0.3, b = √3/2 a, f_Fe5Si3 = 8.4%, r_Fe5Si3 = 102 nm, f_B2 = 34%, r_B2 = 220 nm",
          "model_note": "Δσp = 54 MPa (silicides) + 111 MPa (B2) for BCC matrix; 55 MPa (silicides) for B2-type matrix"
        },
        {
          "model_name": "Bailey-Hirsch dislocation strengthening",
          "equation_role": "Dislocation strengthening contribution",
          "parameters": "α = 0.2, ρdd_BCC = 4.46 × 10^15 m^-2, ρdd_B2 = 3.36 × 10^15 m^-2",
          "model_note": "Δσd = 687 MPa (BCC) and 590 MPa (B2-type)"
        },
        {
          "model_name": "Fleischer solid solution strengthening",
          "equation_role": "Solid solution strengthening contribution",
          "parameters": "Al as solute, c_BCC = 13.45 at.%, c_B2 = 36.55 at.%",
          "model_note": "Δσss = 106 MPa (BCC) and 177 MPa (B2-type)"
        },
        {
          "model_name": "Rietveld refinement",
          "equation_role": "Structural and microstructural parameter determination",
          "parameters": "GSAS-II, pseudo-Voigt profile, Chebyschev-I background with 10 coefficients",
          "model_note": "Lattice parameters, crystallite sizes, microstrain, and phase fractions determined for milled, annealed, and SPSed samples"
        }
      ]
    }
