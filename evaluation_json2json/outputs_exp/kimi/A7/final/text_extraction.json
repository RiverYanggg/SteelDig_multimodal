  "computational_details": [
    {
      "computation_id": "comp_01",
      "sample_id": null,
      "simulation_method": "Thermodynamic equilibrium calculation",
      "software_used": "Thermo-Calc with TCFE9 steel database",
      "potential_model": null,
      "validation_against_experiment": "Predicted intercritical temperature window broadened with Al and Si additions. Predicted equilibrium austenite fractions at 700°C were approximately 48-50% for M1 and 30-32% for M2. Observed retained austenite fractions after IA were 45% and 19% respectively, indicating partial martensitic transformation during cooling not captured by equilibrium predictions alone.",
      "analytical_model": []
    },
    {
      "computation_id": "comp_02",
      "sample_id": null,
      "simulation_method": "Empirical martensite-start temperature calculation and Koistinen-Marburger model",
      "software_used": null,
      "potential_model": null,
      "validation_against_experiment": "Calculated Ms temperatures for hot-rolled samples were 319°C (M1) and 296°C (M2). For IA conditions, the K-M model predicted retained austenite fractions of approximately 16% for M1 and 11% for M2 at room temperature, which are significantly lower than observed values of 45% and 19%, suggesting additional local microstructural heterogeneity factors enhance austenite stability.",
      "analytical_model": [
        {
          "model_name": "Mahieu-De Cooman-Maki Ms equation",
          "equation_role": "Calculate martensite start temperature from austenite composition",
          "parameters": "Ms(°C) = 539 - 423C - 30.4Mn - 7.5Si + 30Al, with elemental concentrations in wt.%",
          "model_note": "Austenite composition at the relevant processing temperature used as input."
        },
        {
          "model_name": "Koistinen-Marburger equation",
          "equation_role": "Predict retained austenite fraction as a function of undercooling below Ms",
          "parameters": "(1 - f) = exp{-0.011[Ms - T]}",
          "model_note": "Applied to calculate retained austenite at room temperature using calculated Ms."
        }
      ]
    },
    {
      "computation_id": "comp_03",
      "sample_id": null,
      "simulation_method": "Mechanical stability fitting of retained austenite transformation kinetics during tensile deformation",
      "software_used": null,
      "potential_model": null,
      "validation_against_experiment": "Fitting parameter B obtained as 3.6 for M1 and 3.8 for M2. Lower B for M1 indicates higher mechanical stability and slower TRIP kinetics, consistent with higher retained austenite fraction and finer grains.",
      "analytical_model": [
        {
          "model_name": "Exponential decay model for austenite transformation",
          "equation_role": "Model austenite volume fraction as a function of true strain during tensile testing",
          "parameters": "f_γ = A × e^{-Bε}; B = 3.6 for M1, B = 3.8 for M2",
          "model_note": "A represents initial austenite fraction before tensile test."
        }
      ]
    }
  ],
  "unmapped_findings": [
    "Product of strength and elongation (PSE) values: 61 GPa% for M1-IA and 41 GPa% for M2-IA.",
    "Retained austenite fractions after tensile fracture determined by EBSD: 6.5% for M1-IA and 3.2% for M2-IA, confirming deformation-induced martensitic transformation (TRIP effect).",
    "Stacking fault energy (SFE) values of both steels are below 18 mJ/m², which is the critical SFE for TRIP effect occurrence.",
    "Calculated Ms temperatures for hot-rolled austenite compositions: 319°C for M1 and 296°C for M2, supporting martensite formation during air cooling after hot rolling.",
    "Grain size distribution analysis (Fig. 8b) indicates M1-IA contains a higher fraction of austenite grains smaller than 0.5 μm compared to M2-IA, contributing to higher local austenite stability.",
    "Fig. 7 XRD data table indicates 45.6% austenite for M1-IA, whereas abstract and main text consistently report 45%; the main text value is used as the authoritative figure.",
    "Dog-bone-shaped tensile specimens had a gauge length of 2 mm, thickness of 1 mm, and width of 1 mm, machined by wire-EDM.",
    "Tensile testing was performed on a Tinus-Olsen ST25 universal testing machine equipped with a 25 kN load cell.",
    "Fig. 11 contains true stress, strain hardening rate, and retained austenite fraction versus true strain plots; precise numerical coordinates beyond point A (1338 MPa) and point B (989 MPa) are not provided in the text.",
    "Engineering stress-strain curves and fractography images are provided in Fig. 10; HR samples exhibit brittle cleavage with river markings, while IA samples exhibit ductile dimple rupture."
