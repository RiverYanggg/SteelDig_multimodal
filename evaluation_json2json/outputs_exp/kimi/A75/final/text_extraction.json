    {
      "computation_id": "comp_001",
      "sample_id": null,
      "simulation_method": null,
      "software_used": "Nano-Measurer",
      "potential_model": null,
      "validation_against_experiment": "Grain size results validated against TEM dark-field images",
      "analytical_model": [
        {
          "model_name": "Williamson-Hall analysis",
          "equation_role": "XRD peak broadening analysis to separate grain refinement and microstrain contributions",
          "parameters": "K=0.9, λ=0.15406 nm",
          "model_note": "Equation (1): β_τ = Kλ/(D cos θ) + 4ε tan θ; applied to FWHM data of austenitic peaks."
        },
        {
          "model_name": "Dislocation density calculation",
          "equation_role": "Calculate dislocation density from average grain size and microstrain",
          "parameters": "Burgers vector b",
          "model_note": "Equation (2): ρ = 2√3 (ε²)^½ / (D b); results range from 3.2×10¹⁴ to 23.6×10¹⁴ m⁻²."
        },
        {
          "model_name": "Hall-Petch relationship",
          "equation_role": "Explain grain refinement strengthening",
          "parameters": "σ₀, k_s, k_T",
          "model_note": "σ_s = σ₀ + k_s d⁻½ for slip; σ_T = σ₀′ + k_T d⁻½ for twinning, where k_T > k_s for FCC metals."
        },
        {
          "model_name": "Taylor strain hardening law",
          "equation_role": "Explain dislocation strengthening during tensile deformation",
          "parameters": null,
          "model_note": "Classical Taylor hardening describing increased flow stress due to dislocation forest formation."
        },
        {
          "model_name": "Hart's tensile necking criterion",
          "equation_role": "Explain strength-ductility trade-off and necking condition",
          "parameters": "Θ, m, σ, ε, ε̇_P, T",
          "model_note": "Equation (3): Θ ≤ σ(1−m), where Θ is strain hardening rate and m is strain rate sensitivity factor."
        }
      ]
    }
  ],
  "unmapped_findings": [
    "Tensile dog-bone specimens had a gauge segment of 20 × 5 × 1 mm and were machined along the rolling direction; tensile tests were conducted at a crosshead speed of 0.2 mm min⁻¹.",
    "Microhardness measurements were performed with a 500 g load and 15 s dwelling time, with reported HV values averaged from at least 5 measurements.",
    "Figure 8a provides engineering stress–strain curves for all deformation levels, but continuous curve data are not available in the provided text pipeline without image pixels.",
    "The stacking fault energy (SFE) of the steel is reported as 72 mJ m⁻² at room temperature and 51 mJ m⁻² at cryogenic temperature.",
    "Fracture morphology transitions from ductile fracture with large and deep dimples in the undeformed state to a ductile-brittle mixed fracture mode with partial cleavage features at 90% CR reduction.",
    "Texture evolution from copper {112}<111> at CR 30% to brass {110}<112> at CR 90% was observed via EBSD.",
    "At CR 90%, wave-like micro-shear bands with high internal dislocation density and nanocrystalline grains with random orientation (continuous SAED rings) were observed.",
    "XRD analysis confirmed that no deformation-induced martensitic phase transformation occurred during the entire cryogenic rolling process.",
    "The undeformed state exhibited 94.65% HAGBs; after 30% CR, LAGBs increased to 89.4%; after 90% CR, LAGBs accounted for 94.1%.",
    "The density of the test steel was determined to be 6.82 g cm⁻³."
  ]
}