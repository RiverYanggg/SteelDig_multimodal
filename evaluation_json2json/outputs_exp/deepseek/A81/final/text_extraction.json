  "computational_details": [
    {
      "computation_id": "comp_model_multiphase",
      "sample_id": null,
      "simulation_method": "Iso-work theory + von Mises equivalent back stress + Mecking-Kocks dislocation evolution + Olson-Cohen martensite kinetics + Hall-Petch",
      "software_used": null,
      "potential_model": null,
      "validation_against_experiment": "Model fits well with experimental flow stress; back stress and phase contributions quantified.",
      "analytical_model": [
        {
          "model_name": "Iso-work theory",
          "equation_role": "Assumes equal tensile work across phases to distribute flow stress and strain increment.",
          "parameters": "σ_F dε_F = σ_B/TM dε_B/TM = σ_FM dε_FM = σ_RA dε_RA = σ_DIM dε_DIM",
          "model_note": "Eq. (1)"
        },
        {
          "model_name": "Olson-Cohen model",
          "equation_role": "Martensitic transformation kinetics to calculate f_DIM from RA fraction.",
          "parameters": "α=5, β=1.28, n=0.55",
          "model_note": "Eq. (3)"
        },
        {
          "model_name": "Hall-Petch relation",
          "equation_role": "Grain boundary strengthening for F and RA.",
          "parameters": "σ0_F=100 MPa, K_F=600 MPa·μm^{1/2}; σ0_RA=180 MPa, K_RA=149 MPa·μm^{1/2}",
          "model_note": "Eq. (14)"
        },
        {
          "model_name": "Taylor dislocation strengthening",
          "equation_role": "Dislocation contribution to flow stress for all phases.",
          "parameters": "α_BCC=0.38, α_FCC=0.35; M_j from EBSD; G_j, b_j given in Table A2",
          "model_note": "Eq. (15)"
        },
        {
          "model_name": "Mecking-Kocks model",
          "equation_role": "Dislocation density evolution with strain.",
          "parameters": "k1, k2, A as per phase; initial ρ0 listed in Table A2",
          "model_note": "Eq. (16)"
        },
        {
          "model_name": "von Mises equivalent back stress",
          "equation_role": "Calculates back stress from GND gradient.",
          "parameters": "ν=0.28, G, b, R, Δh (values in Table A2)",
          "model_note": "Eq. (19)"
        }
      ]
    }
  ],
  "unmapped_findings": [
    "AN750-T achieved a product of strength and elongation (PSE) of 36.3 GPa%.",
