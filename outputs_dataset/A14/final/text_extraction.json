  "papers": [
    {
      "paper_id": "A14",
      "doi": null,
      "title": "Strengthening mechanisms in Fe-Al based ferritic low-density steels",
      "authors": [
        "Sudipta Pramanik",
        "Suresh Koppoju",
        "A.V. Anupama",
        "Balaram Sahoo",
        "Satyam Suwas"
      ],
      "publication_year": null,
      "journal": null,
      "keywords": [
        "Low-density steel",
        "Strengthening mechanisms",
        "Mössbauer spectroscopy",
        "Small angle X-Ray scattering (SAXS)",
        "Fe-Al alloys",
        "ordered phase",
        "dislocation density",
        "X-ray diffraction",
        "transmission electron microscopy"
      ],
      "research_type": "mixed",
      "paper_scope": "To investigate the strengthening mechanisms (dislocation, grain size, ordered phase, solid solution, lattice friction) in Fe-Al based low-density steels with 5-9 wt% Al, with detailed characterization of nano-sized Fe3Al ordered phase and dislocation density evolution, and to deconstruct the yield strength of the Fe-6.8Al alloy into mechanistic contributions."
    }
