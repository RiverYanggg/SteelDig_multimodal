  "processes": [
    {
      "process_id": "proc_hot_rolling",
      "paper_id": "10.1002_srin.202200207",
      "alloy_id": "alloy_fe30mn132al16c5cr",
      "description": "Hot rolling after soaking at 1100-1200 °C for 2 h, followed by rolling at temperature higher than 1000 °C and air cooling.",
      "processes_notes": "Soaking temperature critically affects grain size and DO3 phase formation at grain boundaries. Soaking at 1150 and 1200 °C resulted in intergranular cracking, while 1100 °C allowed successful hot rolling."
    },
    {
      "process_id": "proc_homogenization",
      "paper_id": "10.1002_srin.202200207",
      "alloy_id": "alloy_fe30mn132al16c5cr",
      "description": "Homogenization heat treatment at 1050 °C for 2 h followed by different cooling methods (air cooling vs water quenching).",
      "processes_notes": "Temperature selected to dissolve κ-carbide and minimize grain coarsening. Cooling rate significantly affects DO3 phase formation and tensile properties."
    }
  ],
